# Sarthi BFF — MUST be the Next.js app in novadrive/ (NOT the static brief site).
#
# Wrong (404 on /api/sarthi/health):
#   https://margi-tau.vercel.app
#   https://roadsafetyhackathon-six.vercel.app
#
# Option A — Vercel: deploy novadrive/ as its own project (see docs/PHASE3_SETUP.md), then:
# EXPO_PUBLIC_SARTHI_API_URL=https://novadrive-eta.vercel.app
#
# Option B — Local dev (phone + PC on same Wi‑Fi):
#   cd ../novadrive && npm run dev:lan
#   ipconfig → IPv4, e.g. http://192.168.1.42:3000
# EXPO_PUBLIC_SARTHI_API_URL=http://192.168.1.42:3000
#
# Verify: node scripts/check-sarthi-bff.cjs
EXPO_PUBLIC_SARTHI_API_URL=

# Supabase — use Publishable key (sb_publishable_...) from Dashboard → API Keys
EXPO_PUBLIC_SUPABASE_URL=https://yllcmksndrhlektbjvcu.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key-here

# HTTP dispatch (production endpoints — not dispatch.novadrive.local)
EXPO_PUBLIC_TRAUMA_DISPATCH_URL=https://your-dispatch.example.com/trauma
EXPO_PUBLIC_POLICE_DISPATCH_URL=https://your-dispatch.example.com/police
