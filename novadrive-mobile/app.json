{
  "expo": {
    "name": "NovaDrive",
    "slug": "novadrive-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "novadrive",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.novadrive.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "NovaDrive uses your location during an active journey to route emergencies and build the Golden Hour Packet.",
        "NSCameraUsageDescription": "NovaDrive uses the camera to scan bystander relay QR codes."
      }
    },
    "android": {
      "package": "com.novadrive.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B1220",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "HIGH_SAMPLING_RATE_SENSORS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NovaDrive uses location during an active journey for emergency routing."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "NovaDrive scans QR codes so bystanders can relay your Golden Hour Packet."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
