#!/bin/sh
# Strip Cursor co-author trailers so cursoragent does not appear on GitHub.
sed -i.bak '/cursoragent@cursor\.com/d' "$1" 2>/dev/null || sed -i '' '/cursoragent@cursor\.com/d' "$1" 2>/dev/null
sed -i.bak '/Co-authored-by: Cursor/d' "$1" 2>/dev/null || sed -i '' '/Co-authored-by: Cursor/d' "$1" 2>/dev/null
rm -f "$1.bak" 2>/dev/null
